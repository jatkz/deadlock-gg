# Deadlock API collector settings.
# The public API currently works without a key. Add one if you have sponsored/keyed access.
DEADLOCK_API_BASE_URL=https://api.deadlock-api.com
# DEADLOCK_API_KEY=

# Raspberry Pi output directory.
DEADLOCK_DATA_DIR=data/deadlock-ranked

# "newest" rereads the newest matching page and skips seen IDs.
# "backfill" walks backward by match_id across older matches.
DEADLOCK_SCAN_MODE=newest

# Badge is tier/subtier encoded. 84+ is currently near the stricter side of the top quartile.
DEADLOCK_MIN_AVERAGE_BADGE=84
DEADLOCK_MIN_DURATION_SECONDS=720
# DEADLOCK_MAX_DURATION_SECONDS=7000
DEADLOCK_GAME_MODE=normal
# DEADLOCK_MATCH_MODE=ranked
# DEADLOCK_IS_HIGH_SKILL_RANGE_PARTIES=true

# Include flags for /v1/matches/metadata.
DEADLOCK_INCLUDE_PLAYER_ITEMS=true
DEADLOCK_INCLUDE_PLAYER_STATS=true
DEADLOCK_INCLUDE_PLAYER_DEATH_DETAILS=true
DEADLOCK_SAVE_RAW_MATCH=true

# Cycle sizing and storage.
DEADLOCK_MAX_REQUESTS_PER_RUN=1
DEADLOCK_REQUEST_LIMIT=1000
DEADLOCK_MAX_MATCHES_PER_RUN=250
DEADLOCK_MAX_MATCHES_TOTAL=25000
DEADLOCK_OUTPUT_RECORDS_PER_FILE=1000
DEADLOCK_COMPRESS_OUTPUT=true
DEADLOCK_RETENTION_DAYS=0
DEADLOCK_SECONDS_BETWEEN_REQUESTS=1.0
DEADLOCK_REQUEST_TIMEOUT_SECONDS=30
DEADLOCK_USER_AGENT=deadlock-gg-collector/0.1
DEADLOCK_LOG_LEVEL=info

# Optional player lookup settings for ./deadlock_mmr.
# DEADLOCK_ACCOUNT_ID=123456789
# DEADLOCK_STEAM_ID64=7656119...

# Pull data back from the Pi.
DEADLOCK_PI_SSH=pi@raspberrypi.local
DEADLOCK_PI_REMOTE_DATA_DIR=~/deadlock_gg_collector/data/deadlock-ranked
DEADLOCK_PI_LOCAL_DATA_DIR=data/deadlock-ranked-pi

# Local analysis outputs.
DEADLOCK_ANALYSIS_MAX_MATCHES=25000
DEADLOCK_ASSET_LANGUAGE=english
# DEADLOCK_ASSET_CLIENT_VERSION=
