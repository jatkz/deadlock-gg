#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [[ ! -f .env && -f .env.example ]]; then
  cp .env.example .env
  echo "Created .env from .env.example"
fi

if [[ ! -x venv/bin/python ]]; then
  if command -v python3 >/dev/null 2>&1; then
    python3 -m venv venv
  else
    echo "python3 is not installed on this system." >&2
    exit 1
  fi
fi

chmod +x \
  run_deadlock_collector_cycle.sh \
  pull_deadlock_data_from_pi.sh \
  scripts/deadlock_match_collector.py \
  scripts/build_deadlock_asset_manifest.py \
  scripts/build_deadlock_sqlite_db.py

if [[ ! -f assets/deadlock/manifest.json ]]; then
  venv/bin/python scripts/build_deadlock_asset_manifest.py --pretty
fi

./deploy/deadlock-collector/install_systemd.sh

echo
echo "Deadlock collector is on."
echo "Status:"
echo "  sudo systemctl status deadlock-match-collector.timer"
echo "Logs:"
echo "  sudo journalctl -u deadlock-match-collector.service -n 100 --no-pager"
