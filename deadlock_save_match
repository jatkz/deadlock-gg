#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [[ "$#" -lt 1 ]]; then
  echo "Usage: $0 MATCH_ID [MATCH_ID ...]" >&2
  echo "Saves match ids from the current SQLite DB so future --fresh pulls keep them." >&2
  exit 2
fi

if [[ -x venv/bin/python ]]; then
  PYTHON_BIN="$SCRIPT_DIR/venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
else
  echo "python3 is not installed on this system." >&2
  exit 1
fi

exec "$PYTHON_BIN" scripts/save_deadlock_match.py "$@"
