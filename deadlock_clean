#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [[ "${1:-}" != "--yes" ]]; then
  cat >&2 <<'EOF'
This will remove generated Deadlock collector artifacts:
  data/deadlock-ranked
  data/deadlock-ranked-pi
  data/deadlock-analysis
  collector-dist
  scripts/__pycache__

It will keep .env, assets/deadlock/manifest.json, and data/deadlock-saved.

Run:
  ./deadlock_clean --yes
EOF
  exit 2
fi

./deadlock_off >/dev/null 2>&1 || true

rm -rf \
  data/deadlock-ranked \
  data/deadlock-ranked-pi \
  data/deadlock-analysis \
  collector-dist \
  scripts/__pycache__

echo "Removed generated Deadlock collector artifacts."
